#!/usr/bin/env bash
# nixos-build - Helper to build NixOS configuration from main repo or worktree
# Auto-detects if in worktree and uses correct flake path
# Auto-detects hostname for multi-host configuration

set -euo pipefail

# Detect repo root: env var > git detection from CWD > conventional fallback
REPO_ROOT="${NIXOS_REPO:-}"
if [[ -z "$REPO_ROOT" ]]; then
  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || true)
fi
if [[ -z "$REPO_ROOT" ]]; then
  REPO_ROOT="$HOME/.nixos"
fi

# Check for gentle-ai config updates (silent, non-blocking)
check_gentle_ai_updates() {
  local sync_script="$REPO_ROOT/bin/sync-gentle-ai"
  
  # Skip if no sync script (should exist after install)
  [[ ! -x "$sync_script" ]] && return 0
  
  # Skip if in worktree (assume dev mode, don't nag)
  local current_dir="$PWD"
  if [[ "$current_dir" == "$REPO_ROOT/.worktrees"* ]]; then
    return 0
  fi
  
  # Run check silently, capture output
  local check_output
  if ! check_output=$("$sync_script" --check 2>&1); then
    return 0  # If check fails, ignore silently
  fi
  
  # Check if there are changes (look for "Total changes:" with number > 0)
  if echo "$check_output" | grep -q "Total changes:.*[^0]"; then
    local changes=$(echo "$check_output" | grep "Total changes:" | sed 's/.*Total changes:.*[^0-9]\([0-9]\+\).*/\1/')
    echo ""
    echo "⚠️  WARNING: gentle-ai upstream has $changes pending configuration changes"
    echo ""
    echo "   To sync (recommended before build):"
    echo "     sync-gentle-ai --apply"
    echo ""
    echo "   To review first:"
    echo "     sync-gentle-ai --check"
    echo ""
    echo "   Or skip and continue with build..."
    echo ""
    
    # Ask user if they want to abort and sync first
    if [[ -t 0 ]]; then  # Only if stdin is a terminal (interactive)
      read -p "Continue with build without syncing? [Y/n] " -n 1 -r
      echo ""
      if [[ $REPLY =~ ^[Nn]$ ]]; then
        echo "Aborted. Run 'sync-gentle-ai --apply' first, then retry."
        exit 0
      fi
    fi
  fi
}

# Run the check
check_gentle_ai_updates

# Detect if we're in a worktree
get_flake_path() {
  local current_dir="$PWD"
  
  # Check if we're in a worktree
  if [[ "$current_dir" == "$REPO_ROOT/.worktrees"* ]]; then
    # In worktree - use current directory
    echo "."
  elif [[ "$current_dir" == "$REPO_ROOT"* ]]; then
    # In main repo
    echo "/etc/nixos"
  else
    # Outside repo - assume main repo
    echo "/etc/nixos"
  fi
}

FLAKE_PATH=$(get_flake_path)

# Detect hostname for multi-host configuration
HOSTNAME=$(hostname)

# Parse command
COMMAND="${1:-switch}"

# Validate command
if [[ "$COMMAND" == "help" ]] || [[ "$COMMAND" == "-h" ]] || [[ "$COMMAND" == "--help" ]]; then
  echo "Usage: nixos-build [command]"
  echo ""
  echo "Commands:"
  echo "  switch     Build and activate (default)"
  echo "  upgrade    Build and upgrade"
  echo "  dry        Dry-activate (show changes only)"
  echo "  check      Validate flake"
  echo "  build      Dry-build only"
  echo ""
  echo "Auto-detects:"
  echo "  - Hostname: selects correct nixosConfiguration"
  echo "  - Worktree: uses current directory (else /etc/nixos)"
  echo "  - gentle-ai updates: warns if upstream config differs"
  echo ""
  echo "Related commands:"
  echo "  sync-gentle-ai --check   Preview upstream config changes"
  echo "  sync-gentle-ai --apply   Apply upstream config changes"
  exit 0
fi

case "$COMMAND" in
  switch)
    echo ""
    echo "> Building NixOS configuration (switch)..."
    echo "> Using flake: $FLAKE_PATH#$HOSTNAME"
    sudo nixos-rebuild switch --flake "$FLAKE_PATH#$HOSTNAME"
    ;;
  upgrade)
    echo ""
    echo "> Building NixOS configuration (upgrade)..."
    echo "> Using flake: $FLAKE_PATH#$HOSTNAME"
    sudo nixos-rebuild switch --upgrade --flake "$FLAKE_PATH#$HOSTNAME"
    ;;
  dry)
    echo "> Dry-activating (showing changes)..."
    echo "> Using flake: $FLAKE_PATH#$HOSTNAME"
    sudo nixos-rebuild dry-activate --flake "$FLAKE_PATH#$HOSTNAME"
    ;;
  check)
    echo "> Validating flake..."
    nix flake check
    ;;
  build)
    echo "> Dry-building..."
    nix build "$FLAKE_PATH#nixosConfigurations.$HOSTNAME.config.system.build.toplevel"
    ;;
  *)
    echo "Unknown command: $COMMAND"
    echo "Run 'nixos-build help' for usage"
    exit 1
    ;;
esac

