#!/usr/bin/env bash
set -euo pipefail

# Manual SDD generation script for gentle-ai
# Generates complete SDD structure (skills, commands, PERSONA.md, plugins) via Docker
# and copies files to the repository for declarative management via Nix

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OPENCODE_SDD_DIR="${REPO_ROOT}/modules/home/opencode"
CONTAINER_CONFIG_DIR="/tmp/opencode-container"

echo "=========================================="
echo "  Generating OpenCode SDD Structure"
echo "=========================================="
echo ""

# Check if docker is available
if ! command -v docker &> /dev/null; then
  echo "Error: docker not found in PATH"
  echo "Make sure docker is installed and accessible"
  exit 1
fi

# Create temporary directory for container output
mkdir -p "$CONTAINER_CONFIG_DIR"

# Detect latest gentle-ai version from GitHub
echo "> Fetching latest gentle-ai version..."
LATEST_RELEASE=$(curl -s https://api.github.com/repos/Gentleman-Programming/gentle-ai/releases/latest | grep -E '"tag_name"' | head -1 | cut -d'"' -f4 | sed 's/^v//')

if [ -z "$LATEST_RELEASE" ]; then
  echo "Error: Could not fetch latest version from GitHub"
  exit 1
fi

GENTLE_AI_URL="https://github.com/Gentleman-Programming/gentle-ai/releases/download/v${LATEST_RELEASE}/gentle-ai_${LATEST_RELEASE}_linux_amd64.tar.gz"

echo "> Latest version: v${LATEST_RELEASE}"
echo "> Setting up temporary Node.js container for SDD generation..."
echo ""

# Run docker container with Node.js (includes npm, runs as root)
sudo docker run --rm \
  -v "$CONTAINER_CONFIG_DIR:/tmp/opencode" \
  node:lts-slim bash -c '
    set -euo pipefail

    echo "> Installing dependencies..."
    apt-get update >/dev/null 2>&1
    apt-get install -y curl git >/dev/null 2>&1

    echo "> Downloading gentle-ai v'"${LATEST_RELEASE}"'..."
    cd /tmp
    curl -sSL "'"${GENTLE_AI_URL}"'" | tar xz

    echo "> Running gentle-ai install --preset full-gentleman..."
    ./gentle-ai install --agent opencode --preset full-gentleman 2>&1 || true

    echo "> Copying generated structure to /tmp/opencode..."
    if [ -d ~/.config/opencode ]; then
      cp -r ~/.config/opencode/* /tmp/opencode/ 2>/dev/null || true
    fi

    echo "> SDD generation complete!"
  '

echo ""
echo "=========================================="
echo "  Copying to Repository"
echo "=========================================="
echo ""

# Copy generated files to repo
echo "> Copying skills/ directory..."
rm -rf "${OPENCODE_SDD_DIR}/skills"
cp -r "$CONTAINER_CONFIG_DIR/skills" "${OPENCODE_SDD_DIR}/"

echo "> Copying commands/ directory..."
rm -rf "${OPENCODE_SDD_DIR}/commands"
cp -r "$CONTAINER_CONFIG_DIR/commands" "${OPENCODE_SDD_DIR}/"

echo "> Copying plugins/ directory..."
rm -rf "${OPENCODE_SDD_DIR}/plugins"
cp -r "$CONTAINER_CONFIG_DIR/plugins" "${OPENCODE_SDD_DIR}/"

echo "> Copying PERSONA.md..."
cp "$CONTAINER_CONFIG_DIR/AGENTS.md" "${OPENCODE_SDD_DIR}/PERSONA.md"

echo "> Adjusting engram MCP path in opencode.json..."
jq '.mcp.engram.command = ["engram", "mcp", "--tools=agent"] | .provider = {}' \
  "$CONTAINER_CONFIG_DIR/opencode.json" > "${OPENCODE_SDD_DIR}/opencode.json.base"

# Cleanup
rm -rf "$CONTAINER_CONFIG_DIR"

echo ""
echo "=========================================="
echo "✓ SDD structure updated successfully!"
echo "=========================================="
echo ""
echo "Updated files at: ${OPENCODE_SDD_DIR}"
echo "Next steps:"
echo "  1. Review changes: cd $REPO_ROOT && git diff modules/home/opencode/"
echo "  2. Commit: git add modules/home/opencode/ && git commit -m 'update: refresh opencode SDD'"
echo "  3. Rebuild: nixos-build switch"
echo ""

