#!/bin/bash
# migrate-to-srv-glats.sh
# Migrates all data from Archlinux to /srv/glats/

set -euo pipefail

SOURCE_BASE="/run/media/archlinux/home/glats/home-server"
DEST_BASE="/srv/glats"
BACKUP_BASE="/var/backups/migration-$(date +%Y%m%d-%H%M%S)"
HOST=$(hostname)
LOG_FILE="/var/log/migration-srv-glats.log"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log() {
    echo -e "${BLUE}[$(date '+%H:%M:%S')]${NC} $1" | tee -a "$LOG_FILE"
}

ok() {
    echo -e "${GREEN}[OK]${NC} $1" | tee -a "$LOG_FILE"
}

warn() {
    echo -e "${YELLOW}[WARN]${NC} $1" | tee -a "$LOG_FILE"
}

error() {
    echo -e "${RED}[ERROR]${NC} $1" | tee -a "$LOG_FILE"
    exit 1
}

# ============================================
# INITIAL CHECKS
# ============================================
log "=== Initial Checks ==="

if [[ ! -d "$SOURCE_BASE" ]]; then
    error "Source directory not found: $SOURCE_BASE"
fi

if [[ ! -d "$DEST_BASE" ]]; then
    log "Creating $DEST_BASE..."
    sudo mkdir -p "$DEST_BASE"
    sudo chown glats:users "$DEST_BASE"
fi

# Jellyfin is already in destination (we moved it before)
if [[ -d "/var/lib/jellyfin-migration" ]]; then
    warn "Jellyfin is still in /var/lib/jellyfin-migration/"
    warn "Should already be in $DEST_BASE/jellyfin/"
fi

log "Source space: $(du -sh "$SOURCE_BASE" 2>/dev/null | cut -f1)"
log "Available space in /srv: $(df -h /srv | tail -1 | awk '{print $4}')"

# ============================================
# MIGRATION FUNCTION
# ============================================
migrate_service() {
    local service=$1
    local description=$2
    local source="$SOURCE_BASE/$service"
    local dest="$DEST_BASE/$service"
    
    log ""
    log "=== Migrating: $service ==="
    log "Description: $description"
    
    if [[ ! -d "$source" ]]; then
        warn "Source $source does not exist, skipping..."
        return 0
    fi
    
    # Backup if exists in destination
    if [[ -d "$dest" ]]; then
        log "Backing up existing to $BACKUP_BASE/$service/"
        sudo mkdir -p "$BACKUP_BASE"
        sudo mv "$dest" "$BACKUP_BASE/"
    fi
    
    # Create destination directory
    sudo mkdir -p "$dest"
    
    # rsync with attribute preservation
    log "Copying data..."
    sudo rsync -avAX --progress "$source/" "$dest/" 2>&1 | tee -a "$LOG_FILE" | grep -E "(sent|received|speedup)" || true
    
    # Permissions according to service type
    case "$service" in
        jellyfin|guacamole|fileshelter|cobalt|wetty)
            # OCI Containers: user 1000:1000
            sudo chown -R 1000:1000 "$dest"
            sudo chmod -R u+rw "$dest"
            ;;
        nginx)
            # nginx: root
            sudo chown -R root:root "$dest"
            sudo chmod 600 "$dest/.htpasswd" 2>/dev/null || true
            ;;
        gonic|code)
            # Native services: glats
            sudo chown -R glats:users "$dest"
            ;;
        samba)
            # Samba config: root
            sudo chown -R root:root "$dest"
            ;;
    esac
    
    ok "$service migrated to $dest"
}

# ============================================
# MIGRATION BY SERVICE
# ============================================

# OCI Services
migrate_service "nginx" "Web server + htpasswd + repo (788MB)"
migrate_service "guacamole" "Remote desktop (3 containers)"
migrate_service "wetty" "Web terminal"
migrate_service "fileshelter" "File upload service"
migrate_service "cobalt" "Media downloader"

# Native Services
migrate_service "gonic" "Music streaming (only gonic.db is critical)"
migrate_service "code" "VS Code settings and project"
migrate_service "samba" "Samba configuration"

# Optional (ask)
log ""
log "=== Optional Services ==="

read -p "Migrate searxng (search engine)? [y/N]: " m_searxng
if [[ "$m_searxng" =~ ^[Yy]$ ]]; then
    migrate_service "searxng" "Meta search engine"
fi

read -p "Migrate fail2ban (security logs)? [y/N]: " m_fail2ban
if [[ "$m_fail2ban" =~ ^[Yy]$ ]]; then
    migrate_service "fail2ban" "Intrusion prevention"
fi

# ============================================
# JELLYFIN VERIFICATION
# ============================================
log ""
log "=== Jellyfin Verification ==="

if [[ -d "$DEST_BASE/jellyfin" ]]; then
    ok "Jellyfin is in $DEST_BASE/jellyfin/"
    log "Checking permissions..."
    ls -la "$DEST_BASE/jellyfin/" | head -5
else
    warn "Jellyfin NOT found in destination"
    warn "Should be at: $DEST_BASE/jellyfin/"
fi

# ============================================
# SUMMARY
# ============================================
log ""
log "=== MIGRATION COMPLETED ==="
log ""
log "Created structure:"
ls -la "$DEST_BASE/"
log ""
log "Total space used: $(du -sh "$DEST_BASE" | cut -f1)"
log "Backup created at: $BACKUP_BASE"
log "Full log: $LOG_FILE"
log ""
log "Next steps:"
log "1. Verify all services work"
log "2. Run: sudo nixos-rebuild switch --flake '/home/glats/.nixos#${HOST}'"
log "3. Test each service"
log "4. Once everything confirmed OK, unmount Archlinux partition"
