#!/usr/bin/env bash
set -euo pipefail

# sync-gentle-ai: Automatic configuration synchronization from gentle-ai upstream
# 
# This script clones the gentle-ai repository, extracts the embedded assets
# (skills, commands, plugins), and synchronizes them with the NixOS repository.
#
# Note: We cannot run 'gentle-ai install' directly because it fails on NixOS
# distro detection. Instead, we extract assets from the source code.
#
# Usage:
#   sync-gentle-ai [--check|--apply|--auto] [nixos-dir]
#
#   --check   Show what would change (default)
#   --apply   Actually apply the changes
#   --auto    Apply changes and auto-commit if there are updates

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NIXOS_DIR="${2:-$(dirname "$SCRIPT_DIR")}"
MODE="${1:-check}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Pattern to ignore when comparing skills (ORCHESTRATOR GATE)
ORCHESTRATOR_GATE_PATTERN='ORCHESTRATOR GATE'

# Function to compare files ignoring orchestrator gates and whitespace
files_equal_ignore_gates() {
  local file1="$1"
  local file2="$2"
  
  # Create temporary files without orchestrator gate lines
  local tmp1=$(mktemp)
  local tmp2=$(mktemp)
  
  # Remove orchestrator gate lines (case-insensitive)
  grep -v -i "$ORCHESTRATOR_GATE_PATTERN" "$file1" > "$tmp1"
  grep -v -i "$ORCHESTRATOR_GATE_PATTERN" "$file2" > "$tmp2"
  
  # Compare the filtered files, ignoring whitespace and blank lines
  if diff -w -B -q "$tmp1" "$tmp2" > /dev/null 2>&1; then
    rm -f "$tmp1" "$tmp2"
    return 0
  else
    # DEBUG: show filtered diff for first few lines
    if [[ -n "${DEBUG_SYNC:-}" ]]; then
      echo "DEBUG: files differ after removing ORCHESTRATOR GATE"
      echo "--- filtered $file1"
      head -30 "$tmp1"
      echo "--- filtered $file2"
      head -30 "$tmp2"
      echo "--- diff -u"
      diff -u "$tmp1" "$tmp2" | head -50
    fi
    rm -f "$tmp1" "$tmp2"
    return 1
  fi
}

# Temporary directory setup
TEMP_DIR=$(mktemp -d)
trap "rm -rf $TEMP_DIR" EXIT

UPSTREAM_DIR="$TEMP_DIR/gentle-ai"

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}  gentle-ai Config Synchronization${NC}"
echo -e "${BLUE}========================================${NC}"
echo ""
echo -e "Mode: ${CYAN}$MODE${NC}"
echo -e "NixOS dir: ${CYAN}$NIXOS_DIR${NC}"
echo ""

# Fetch latest version from GitHub
echo -e "${BLUE}Fetching latest gentle-ai version...${NC}"
LATEST_VERSION=$(curl -s https://api.github.com/repos/Gentleman-Programming/gentle-ai/releases/latest | jq -r .tag_name | sed 's/^v//')
echo -e "Latest upstream version: ${CYAN}$LATEST_VERSION${NC}"

# Check current local gentle-ai version
CURRENT_VERSION=$(grep 'version = ' "$NIXOS_DIR/pkgs/gentle-ai/default.nix" | head -1 | cut -d'"' -f2)
echo -e "Current nix package version: ${CYAN}$CURRENT_VERSION${NC}"
echo ""

# Clone the repository (shallow clone, just the files we need)
echo -e "${BLUE}Cloning gentle-ai repository...${NC}"
if ! git clone --depth 1 --filter=blob:none --sparse \
    https://github.com/Gentleman-Programming/gentle-ai.git \
    "$UPSTREAM_DIR" 2>&1; then
    echo -e "${RED}Error: Failed to clone repository${NC}"
    exit 1
fi

# Checkout only the assets directory we need
cd "$UPSTREAM_DIR"
git sparse-checkout set internal/assets/skills internal/assets/opencode internal/assets/generic internal/assets/_shared 2>&1 || true

echo -e "${GREEN}✓ Repository cloned${NC}"
echo ""

# Source directories
SKILLS_SRC="$UPSTREAM_DIR/internal/assets/skills"
COMMANDS_SRC="$UPSTREAM_DIR/internal/assets/opencode/commands"
PLUGINS_SRC="$UPSTREAM_DIR/internal/assets/opencode/plugins"
GENERIC_SRC="$UPSTREAM_DIR/internal/assets/generic"

# Destination directories
SKILLS_DST="$NIXOS_DIR/modules/home/opencode/skills"
COMMANDS_DST="$NIXOS_DIR/modules/home/opencode/commands"
PLUGINS_DST="$NIXOS_DIR/modules/home/opencode/plugins"
AGENTS_DST="$NIXOS_DIR/modules/home/opencode/AGENTS.md"

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}  Comparing configurations${NC}"
echo -e "${BLUE}========================================${NC}"
echo ""

# Custom skills that should NOT be overwritten (local additions)
CUSTOM_SKILLS=("nix-search" "caveman" "caveman-commit" "caveman-review"
               "sdd-apply" "sdd-archive" "sdd-design" "sdd-explore"
               "sdd-init" "sdd-onboard" "sdd-propose" "sdd-spec"
               "sdd-tasks" "sdd-verify")

# Function to check if a skill is custom
is_custom_skill() {
    local skill="$1"
    # Match exact custom skills
    for custom in "${CUSTOM_SKILLS[@]}"; do
        if [[ "$skill" == "$custom" ]]; then
            return 0
        fi
    done
    # Match any skill starting with sdd- (SDD phase skills)
    if [[ "$skill" == sdd-* ]]; then
        return 0
    fi
    return 1
}

# Counter for changes
CHANGES=0
NEW_SKILLS=()
UPDATED_SKILLS=()
UPDATED_COMMANDS=()
UPDATED_PLUGINS=()

# Check if source directories exist
check_source() {
    local src="$1"
    local name="$2"
    if [[ ! -d "$src" ]]; then
        echo -e "  ${RED}ERROR${NC} $name source not found at $src"
        return 1
    fi
    return 0
}

# Sync skills
echo -e "${CYAN}Skills comparison:${NC}"
if check_source "$SKILLS_SRC" "Skills"; then
    for skill_dir in "$SKILLS_SRC"/*/; do
        [[ ! -d "$skill_dir" ]] && continue
        
        skill_name=$(basename "$skill_dir")
        
        # Skip _shared for now (handled separately)
        [[ "$skill_name" == "_shared" ]] && continue
        
        # Skip custom skills
        if is_custom_skill "$skill_name"; then
            echo -e "  ${YELLOW}SKIP${NC} $skill_name (local custom skill)"
            continue
        fi
        
        skill_file="$skill_dir/SKILL.md"
        if [[ -f "$skill_file" ]]; then
            dst_file="$SKILLS_DST/$skill_name/SKILL.md"
            
            if [[ ! -f "$dst_file" ]]; then
                echo -e "  ${GREEN}NEW${NC}  $skill_name"
                NEW_SKILLS+=("$skill_name")
                CHANGES=$((CHANGES + 1))
            elif ! files_equal_ignore_gates "$skill_file" "$dst_file"; then
                echo -e "  ${YELLOW}DIFF${NC} $skill_name"
                UPDATED_SKILLS+=("$skill_name")
                CHANGES=$((CHANGES + 1))
            fi
        fi
    done
fi
echo ""

# Sync _shared files
echo -e "${CYAN}Shared conventions (_shared):${NC}"
SHARED_SRC="$SKILLS_SRC/_shared"
SHARED_DST="$SKILLS_DST/_shared"

if [[ -d "$SHARED_SRC" ]]; then
    for shared_file in "$SHARED_SRC"/*.md; do
        [[ ! -f "$shared_file" ]] && continue
        
        filename=$(basename "$shared_file")
        dst_file="$SHARED_DST/$filename"
        
        if [[ ! -f "$dst_file" ]]; then
            echo -e "  ${GREEN}NEW${NC}  _shared/$filename"
            CHANGES=$((CHANGES + 1))
        elif ! files_equal_ignore_gates "$shared_file" "$dst_file"; then
            echo -e "  ${YELLOW}DIFF${NC} _shared/$filename"
            CHANGES=$((CHANGES + 1))
        fi
    done
fi
echo ""

# Sync commands
echo -e "${CYAN}Commands comparison:${NC}"
if check_source "$COMMANDS_SRC" "Commands"; then
    for cmd_file in "$COMMANDS_SRC"/*.md; do
        [[ ! -f "$cmd_file" ]] && continue
        
        cmd_name=$(basename "$cmd_file")
        dst_file="$COMMANDS_DST/$cmd_name"
        
        # Skip custom commands (caveman-*)
        if [[ "$cmd_name" == caveman* ]]; then
            if [[ -f "$dst_file" ]]; then
                echo -e "  ${YELLOW}SKIP${NC} $cmd_name (local custom command)"
            fi
            continue
        fi
        
        if [[ ! -f "$dst_file" ]]; then
            echo -e "  ${GREEN}NEW${NC}  $cmd_name"
            UPDATED_COMMANDS+=("$cmd_name")
            CHANGES=$((CHANGES + 1))
        elif ! files_equal_ignore_gates "$cmd_file" "$dst_file"; then
            echo -e "  ${YELLOW}DIFF${NC} $cmd_name"
            UPDATED_COMMANDS+=("$cmd_name")
            CHANGES=$((CHANGES + 1))
        fi
    done
fi
echo ""

# Sync plugins
echo -e "${CYAN}Plugins comparison:${NC}"
if check_source "$PLUGINS_SRC" "Plugins"; then
    for plugin_file in "$PLUGINS_SRC"/*.ts; do
        [[ ! -f "$plugin_file" ]] && continue
        
        plugin_name=$(basename "$plugin_file")
        dst_file="$PLUGINS_DST/$plugin_name"
        
        # Skip custom plugins (engram.ts)
        if [[ "$plugin_name" == "engram.ts" ]]; then
            if [[ -f "$dst_file" ]]; then
                echo -e "  ${YELLOW}SKIP${NC} $plugin_name (local custom plugin)"
            fi
            continue
        fi
        
        if [[ ! -f "$dst_file" ]]; then
            echo -e "  ${GREEN}NEW${NC}  $plugin_name"
            UPDATED_PLUGINS+=("$plugin_name")
            CHANGES=$((CHANGES + 1))
        elif ! files_equal_ignore_gates "$plugin_file" "$dst_file"; then
            echo -e "  ${YELLOW}DIFF${NC} $plugin_name"
            UPDATED_PLUGINS+=("$plugin_name")
            CHANGES=$((CHANGES + 1))
        fi
    done
fi
echo ""

# Check generic/sdd-orchestrator.md (source for AGENTS.md orchestrator section)
echo -e "${CYAN}Orchestrator (generic/sdd-orchestrator.md):${NC}"
ORCH_SRC="$GENERIC_SRC/sdd-orchestrator.md"
if [[ -f "$ORCH_SRC" ]]; then
    echo -e "  ${CYAN}INFO${NC} Upstream orchestrator available for manual review"
    # We don't auto-sync AGENTS.md because it has local customizations
fi
echo ""

# Summary
echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}  Summary${NC}"
echo -e "${BLUE}========================================${NC}"
echo ""
echo -e "Total changes: ${CYAN}$CHANGES${NC}"
echo ""

if [[ $CHANGES -eq 0 ]]; then
    echo -e "${GREEN}✓ Everything is up to date!${NC}"
    echo -e "Local config matches gentle-ai v${CURRENT_VERSION}"
    exit 0
fi

# Show detailed diff on request
if [[ "$MODE" == "check" ]]; then
    echo -e "${YELLOW}Run with --apply to apply these changes${NC}"
    echo ""
    
    # Show sample diff for first updated skill
    if [[ ${#UPDATED_SKILLS[@]} -gt 0 ]]; then
        first_skill="${UPDATED_SKILLS[0]}"
        echo -e "${CYAN}Sample diff for skill: $first_skill${NC}"
        diff -u "$SKILLS_DST/$first_skill/SKILL.md" "$SKILLS_SRC/$first_skill/SKILL.md" 2>/dev/null | head -60 || \
            echo "(files differ, run with --apply to see full changes)"
        echo ""
    fi
    
    exit 0
fi

# Apply mode
if [[ "$MODE" == "apply" ]] || [[ "$MODE" == "auto" ]]; then
    echo -e "${BLUE}Applying changes from gentle-ai v$LATEST_VERSION...${NC}"
    echo ""
    
    # Apply new/updated skills
    for skill in "${NEW_SKILLS[@]}" "${UPDATED_SKILLS[@]}"; do
        mkdir -p "$SKILLS_DST/$skill"
        cp "$SKILLS_SRC/$skill/SKILL.md" "$SKILLS_DST/$skill/SKILL.md"
        echo -e "${GREEN}✓${NC} Synced skill: $skill"
    done
    
    # Apply new/updated _shared files
    if [[ -d "$SHARED_SRC" ]]; then
        mkdir -p "$SHARED_DST"
        for shared_file in "$SHARED_SRC"/*.md; do
            [[ ! -f "$shared_file" ]] && continue
            filename=$(basename "$shared_file")
            dst_file="$SHARED_DST/$filename"
            
            if [[ ! -f "$dst_file" ]] || ! diff -q "$shared_file" "$dst_file" > /dev/null 2>&1; then
                cp "$shared_file" "$dst_file"
                echo -e "${GREEN}✓${NC} Synced _shared/$filename"
            fi
        done
    fi
    
    # Apply new/updated commands
    for cmd in "${UPDATED_COMMANDS[@]}"; do
        cp "$COMMANDS_SRC/$cmd" "$COMMANDS_DST/$cmd"
        echo -e "${GREEN}✓${NC} Synced command: $cmd"
    done
    
    # Apply new/updated plugins
    for plugin in "${UPDATED_PLUGINS[@]}"; do
        cp "$PLUGINS_SRC/$plugin" "$PLUGINS_DST/$plugin"
        echo -e "${GREEN}✓${NC} Synced plugin: $plugin"
    done
    
    echo ""
    
    # Stage changes
    cd "$NIXOS_DIR"
    git add modules/home/opencode/skills modules/home/opencode/commands modules/home/opencode/plugins
    
    echo -e "${GREEN}✓ Changes staged${NC}"
    echo ""
    
    # Update the version file to track what we synced
    echo "Synced from gentle-ai v$LATEST_VERSION on $(date -Iseconds)" > "$NIXOS_DIR/modules/home/opencode/.last-sync"
    git add modules/home/opencode/.last-sync 2>/dev/null || true
    
    if [[ "$MODE" == "auto" ]]; then
        # Auto-commit
        COMMIT_MSG="chore(opencode): sync gentle-ai v${LATEST_VERSION} upstream

Changes:
$(if [[ ${#NEW_SKILLS[@]} -gt 0 ]]; then echo ""; echo "New skills:"; for s in "${NEW_SKILLS[@]}"; do echo "- $s"; done; fi)
$(if [[ ${#UPDATED_SKILLS[@]} -gt 0 ]]; then echo ""; echo "Updated skills:"; for s in "${UPDATED_SKILLS[@]}"; do echo "- $s"; done; fi)
$(if [[ ${#UPDATED_COMMANDS[@]} -gt 0 ]]; then echo ""; echo "Updated commands:"; for c in "${UPDATED_COMMANDS[@]}"; do echo "- $c"; done; fi)
$(if [[ ${#UPDATED_PLUGINS[@]} -gt 0 ]]; then echo ""; echo "Updated plugins:"; for p in "${UPDATED_PLUGINS[@]}"; do echo "- $p"; done; fi)

Custom skills preserved: ${CUSTOM_SKILLS[*]}"
        
        git commit -m "$COMMIT_MSG"
        echo -e "${GREEN}✓ Auto-committed changes${NC}"
        echo ""
        echo -e "${YELLOW}Next steps:${NC}"
        echo "  1. Review the commit: git show HEAD"
        echo "  2. Push if satisfied: git push"
        echo "  3. Rebuild NixOS: nixos-build switch"
    else
        echo -e "${YELLOW}Next steps:${NC}"
        echo "  1. Review changes: git diff --staged"
        echo "  2. Commit: git commit -m 'sync gentle-ai v$LATEST_VERSION'"
        echo "  3. Push: git push"
        echo "  4. Rebuild: nixos-build switch"
    fi
fi
