#!/usr/bin/env bash
set -euo pipefail

# Wrapper for gentle-ai interactive TUI
# Resolves symlinks from Nix store and runs gentle-ai in Docker
# Changes made in the TUI are synced back to ~/.config/opencode/opencode.json

OPENCODE_DIR="${HOME}/.config/opencode"
TEMP_DIR="/tmp/opencode-tui-$$"
BACKUP_FILE="${OPENCODE_DIR}/opencode.json.bak"

echo "=========================================="
echo "  OpenCode Gentle-AI TUI"
echo "=========================================="
echo ""

# Cleanup function
cleanup() {
  echo ""
  echo "> Cleaning up temporary directory..."
  rm -rf "$TEMP_DIR"
}
trap cleanup EXIT

# Check if docker is available
if ! command -v docker &> /dev/null; then
  echo "Error: docker not found in PATH"
  exit 1
fi

# Create backup of current opencode.json
echo "> Creating backup of opencode.json..."
cp "$OPENCODE_DIR/opencode.json" "$BACKUP_FILE"
echo "  Backup saved to: $BACKUP_FILE"

# Copy config to temporary directory, resolving symlinks
echo "> Preparing configuration (resolving symlinks)..."
mkdir -p "$TEMP_DIR"
cp -rL "$OPENCODE_DIR"/* "$TEMP_DIR/"
chmod -R u+w "$TEMP_DIR"

# Detect latest gentle-ai version
echo "> Fetching latest gentle-ai version..."
LATEST_RELEASE=$(curl -s https://api.github.com/repos/Gentleman-Programming/gentle-ai/releases/latest | grep -E '"tag_name"' | head -1 | cut -d'"' -f4 | sed 's/^v//')

if [ -z "$LATEST_RELEASE" ]; then
  echo "Error: Could not fetch latest version from GitHub"
  exit 1
fi

GENTLE_AI_URL="https://github.com/Gentleman-Programming/gentle-ai/releases/download/v${LATEST_RELEASE}/gentle-ai_${LATEST_RELEASE}_linux_amd64.tar.gz"

echo "> Latest version: v${LATEST_RELEASE}"
echo "> Launching gentle-ai TUI in Docker..."
echo ""

# Run gentle-ai interactively in Docker
sudo docker run -it --rm \
  -v "$TEMP_DIR:/root/.config/opencode" \
  node:lts-slim bash -c '
    set -euo pipefail

    echo "> Installing dependencies..."
    apt-get update >/dev/null 2>&1
    apt-get install -y curl git >/dev/null 2>&1

    echo "> Downloading gentle-ai v'"${LATEST_RELEASE}"'..."
    cd /tmp
    curl -sSL "'"${GENTLE_AI_URL}"'" | tar xz

    echo "> Running gentle-ai (interactive mode)..."
    ./gentle-ai
  '

echo ""
echo "=========================================="
echo "  Syncing Changes"
echo "=========================================="
echo ""

# Validate that the generated opencode.json is valid
if ! jq empty "$TEMP_DIR/opencode.json" 2>/dev/null; then
  echo "Error: Generated opencode.json is not valid JSON"
  echo "Restoring from backup..."
  cp "$BACKUP_FILE" "$OPENCODE_DIR/opencode.json"
  exit 1
fi

# Copy back the modified opencode.json
echo "> Copying updated configuration back to ~/.config/opencode/..."
cp "$TEMP_DIR/opencode.json" "$OPENCODE_DIR/opencode.json"
chmod u+rw "$OPENCODE_DIR/opencode.json"

echo ""
echo "=========================================="
echo "✓ TUI session complete!"
echo "=========================================="
echo ""
echo "Configuration updated at: ${OPENCODE_DIR}/opencode.json"
echo "Backup available at: ${BACKUP_FILE}"
echo ""
